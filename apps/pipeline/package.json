{
  "name": "@pokepredict/pipeline",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "pnpm --filter @pokepredict/shared build",
    "build": "tsc -p tsconfig.json",
    "pretest": "pnpm --filter @pokepredict/shared build",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "pretypecheck": "pnpm --filter @pokepredict/shared build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/handlers/fetchRaw.ts"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.916.0",
    "@aws-sdk/client-s3": "^3.916.0",
    "@aws-sdk/client-sesv2": "^3.916.0",
    "@aws-sdk/lib-dynamodb": "^3.916.0",
    "@pokepredict/shared": "workspace:*",
    "ulid": "^3.0.1"
  }
}
