# web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# api
AWS_REGION=us-west-2
# Choose one:
CURSOR_SIGNING_SECRET=<your-secret-here>
CURSOR_SIGNING_SECRET_PARAM=/pokepredict/dev/cursor-signing-secret
TABLE_CARDS=Cards
TABLE_PRICES=Prices
TABLE_LATEST_PRICES=LatestPrices
TABLE_HOLDINGS=Holdings
TABLE_ALERTS_BY_USER=AlertsByUser
TABLE_ALERTS_BY_CARD=AlertsByCard
TABLE_SIGNALS=Signals

# pipeline
RAW_BUCKET=<your-bucket-name>
SOURCE_NAME=fixture
INGEST_SCHEDULE_CRON=cron(0 6 * * ? *)
SES_FROM_EMAIL=alerts+dev@example.com
SEED_CARDS_FILE=./data/cards.seed.json

# infra
CDK_DEFAULT_ACCOUNT=<your-aws-account-id>
CDK_DEFAULT_REGION=us-west-2
# Reuses SES_FROM_EMAIL from the pipeline section above.
