# web
NEXT_PUBLIC_API_BASE_URL=/api
API_PROXY_TARGET=http://localhost:3001

# api
AWS_REGION=us-west-2
# Choose one:
CURSOR_SIGNING_SECRET=<your-secret-here>
CURSOR_SIGNING_SECRET_PARAM=/pokepredict/dev/cursor-signing-secret
TABLE_CARDS=Cards
TABLE_PRICES=Prices
TABLE_LATEST_PRICES=LatestPrices
TABLE_HOLDINGS=Holdings
TABLE_ALERTS_BY_USER=AlertsByUser
TABLE_ALERTS_BY_CARD=AlertsByCard
TABLE_SIGNALS=Signals

# pipeline
RAW_BUCKET=<your-bucket-name>
SOURCE_NAME=tcgdex
INGEST_SCHEDULE_CRON=cron(0 6 * * ? *)
SES_FROM_EMAIL=alerts+dev@example.com
TCGDEX_BASE_URL=https://api.tcgdex.net/v2/en
TCGDEX_LIST_PATH=/cards
TCGDEX_SETS_PATH=/sets
TCGDEX_DETAIL_PATH_TEMPLATE=/cards/{id}
TCGDEX_EXCLUDED_SERIES_IDS=tcgp
TCGDEX_PAGE_SIZE=100
TCGDEX_MAX_PAGES=0
TCGDEX_DETAIL_CONCURRENCY=8
TCGDEX_MAX_RETRIES=2
TCGDEX_RETRY_BASE_DELAY_MS=250
TCGDEX_REQUEST_TIMEOUT_MS=10000
TCGDEX_FAILURE_RATE_THRESHOLD=0.25
TCGDEX_SEED_LIMIT=0
SEED_CARDS_FILE=./data/cards.seed.json

# infra
CDK_DEFAULT_ACCOUNT=<your-aws-account-id>
CDK_DEFAULT_REGION=us-west-2
# Reuses SES_FROM_EMAIL from the pipeline section above.
